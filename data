merged_data = pd.merge(reviews, products, on='productid', how='inner')


def persian_to_finglish(persian_text):


    if pd.isna(persian_text):
        return ""
    persian_text = str(persian_text)
    persian_to_latin = {
        'ا': 'a', 'آ': 'a', 'ب': 'b', 'پ': 'p', 'ت': 't', 'ث': 's',
        'ج': 'j', 'چ': 'ch', 'ح': 'h', 'خ': 'kh', 'د': 'd', 'ذ': 'z',
        'ر': 'r', 'ز': 'z', 'ژ': 'zh', 'س': 's', 'ش': 'sh', 'ص': 's',
        'ض': 'z', 'ط': 't', 'ظ': 'z', 'ع': 'a', 'غ': 'gh', 'ف': 'f',
        'ق': 'gh', 'ک': 'k', 'گ': 'g', 'ل': 'l', 'م': 'm', 'ن': 'n',
        'و': 'v', 'ه': 'h', 'ی': 'y', ' ': ' ', '‌': '', 'ء': '',
        'ك': 'k', 'ي': 'y'
    }

    result = ''
    for char in persian_text:
        if char in persian_to_latin:
            result += persian_to_latin[char]
        else:
            result += char

    return result
try:
    merged_data['description_finglish'] = merged_data['description'].apply(persian_to_finglish)

    all_descriptions = ' '.join(merged_data['description_finglish'].dropna().astype(str))

    wordcloud = WordCloud(
        width=800,
        height=400,
        background_color='white',
        max_words=100
    ).generate(all_descriptions)

    plt.figure(figsize=(12, 6))
    plt.imshow(wordcloud, interpolation='bilinear')
    plt.axis('off')
    plt.title('کلمات پرتکرار در نظرات مشتریان (فینگلیش)')
    plt.show()


    print("نمونه‌ای از نظرات تبدیل شده به فینگلیش:")
    for i, desc in enumerate(merged_data['description_finglish'].head(5)):
        print(f"{i+1}. {desc}")

except Exception as e:
    print(f"خطا در ایجاد wordcloud: {e}")
