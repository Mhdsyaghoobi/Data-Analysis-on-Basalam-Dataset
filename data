from sklearn.cluster import DBSCAN

# اجرای الگوریتم DBSCAN
# پارامتر eps: حداکثر فاصله بین دو نمونه
# پارامتر min_samples: حداقل نمونه در همسایگی برای تشکیل یک خوشه
dbscan = DBSCAN(eps=0.5, min_samples=5)
dbscan_clusters = dbscan.fit_predict(scaled_features)

# افزودن برچسب خوشه‌ها به داده اصلی
merged_data['dbscan_cluster'] = dbscan_clusters

# بررسی تعداد خوشه‌های تشکیل شده و نقاط پرت (خوشه با برچسب -۱)
print("DBSCAN Clusters:", np.unique(dbscan_clusters))





from sklearn.mixture import GaussianMixture

# اجرای مدل مخلوط گاوسی
gmm = GaussianMixture(n_components=3, random_state=42)
gmm_clusters = gmm.fit_predict(scaled_features)

# افزودن برچسب محتمل‌ترین خوشه به داده اصلی
merged_data['gmm_cluster'] = gmm_clusters

# امکان دسترسی به احتمالات تعلق هر نقطه به خوشه‌ها
probabilities = gmm.predict_proba(scaled_features)
print("Membership Probabilities shape:", probabilities.shape)








